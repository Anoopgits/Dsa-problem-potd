  class Solution:
    def operation_make_equal(self, s1, s2):
        if len(s1) != len(s2):
            return False

        chars1 = list(s1)
        chars2 = list(s2)
        n = len(chars1)

        for i in range(n):
            if chars1[i] != chars2[i]:
                idx = self.get_index(chars1, chars2[i], i)
                if idx == -1:
                    return False
                # swap
                chars1[i], chars1[idx] = chars1[idx], chars1[i]

        return self.check_string(chars1, chars2)

    def get_index(self, chars1, target, start):
        n = len(chars1)

        for i in range(start + 1, n):
            if chars1[i] == target and (i - start) == 2:
                return i
        return -1

    def check_string(self, chars1, chars2):
        for i in range(len(chars1)):
            if chars1[i] != chars2[i]:
                return False
        return True

    def canBeEqual(self, s1, s2):
        return self.operation_make_equal(s1, s2)
