class Solution {
    private static boolean operationmakeequal(String s1, String s2) {
        if (s1.length() != s2.length()) return false;

        char[] chars1 = s1.toCharArray();
        char[] chars2 = s2.toCharArray();
        int n = chars1.length;

        for (int i = 0; i < n; i++) {
            if (chars1[i] != chars2[i]) {
                int idx = getindex(chars1, chars2[i], i);
                if (idx == -1) return false;
                // swap
                char temp = chars1[i];
                chars1[i] = chars1[idx];
                chars1[idx] = temp;
            }
        }

        return checkstring(chars1, chars2);
    }

    private static int getindex(char[] chars1, char target, int start) {
        int n = chars1.length;

        for (int i = start + 1; i < n; i++) {
            if (chars1[i] == target && (i - start) == 2) {
                return i;
            }
        }
        return -1;
    }

    private static boolean checkstring(char[] chars1, char[] chars2) {
        for (int i = 0; i < chars1.length; i++) {
            if (chars1[i] != chars2[i]) {
                return false;
            }
        }
        return true;
    }

    public boolean canBeEqual(String s1, String s2) {
        return operationmakeequal(s1, s2);
    }
} 
